    "test:core": "tsx --test src/lib/*.test.ts",
    "ci:core": "npm run lint:core && npm run test:core",
    "audit:pdf": "tsx scripts/audit-pdf-completeness.ts",
    "repair:section-titles": "tsx scripts/repair-section-titles.ts",
    "rescue:pdf": "tsx scripts/rescue-active-pdfs.ts --type=pdf",
    "rescue:docs": "tsx scripts/rescue-active-pdfs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@tailwindcss/typography": "^0.5.19",
